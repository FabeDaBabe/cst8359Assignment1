@model Assignment_1.Models.Attendee
@{
    var eventId = Context.Request.RouteValues["eventId"];
}
<h1>Delete Attendee</h1>
<p>Are you sure you want to delete <strong>@Model.FullName</strong>?</p>
<form asp-controller="Events"
      asp-action="DeleteAttendee"
      asp-route-id="@Model.Id"
      asp-route-eventId="@eventId"
      method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" name="eventId" value="@eventId" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-controller="Events"
       asp-action="Attendees"
       asp-route-eventId="@eventId"
       class="btn btn-secondary">Cancel</a>
</form>