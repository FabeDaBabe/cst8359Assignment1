@model Assignment_1.Models.Event

<h1>Attendees</h1>

@if (Model == null)
{
    <div class="alert alert-warning">Event not found.</div>
}
else
{
    <h3>@Model.Title (@Model.Date.ToString("yyyy-MM-dd"))</h3>
    <p><strong>Location:</strong> @Model.Location</p>

    <h4>Current Attendees</h4>
    @if (!Model.Attendees.Any())
    {
        <p><em>No attendees yet.</em></p>
    }
    else
    {

        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>

                @foreach (var a in Model.Attendees)
                {
                    <tr>
                        <td>@a.FullName</td>
                        <td>@a.Email</td>
                        <td>
                            <a asp-controller="Events"
                               asp-action="EditAttendee"
                               asp-route-id="@a.Id"
                               asp-route-eventId="@Model.Id"
                               class="btn btn-warning btn-sm">Edit</a>

                            <a asp-controller="Events"
                               asp-action="DeleteAttendee"
                               asp-route-id="@a.Id"
                               asp-route-eventId="@Model.Id"
                               class="btn btn-danger btn-sm">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <hr />

    <h4>Add Attendee</h4>
    <form asp-controller="Events" asp-action="Attendees" method="post">
        <input type="hidden" name="eventId" value="@Model.Id" />
        <div class="mb-3">
            <label class="form-label">Full name</label>
            <input name="newAttendee.FullName" class="form-control" />
            <span class="text-danger">
                @if (ViewData.ModelState.ContainsKey("FullName") && ViewData.ModelState["FullName"].Errors.Any())
                {
                    @ViewData.ModelState["FullName"].Errors.First().ErrorMessage
                }
            </span>
        </div>
        <div class="mb-3">
            <label class="form-label">Email</label>
            <input name="newAttendee.Email" class="form-control" />
        </div>
        <button type="submit" class="btn btn-success">Add</button>
        <a asp-controller="Events" asp-action="Index" class="btn btn-secondary">Back to Events</a>
    </form>
}