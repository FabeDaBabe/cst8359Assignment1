@model List<Assignment_1.Models.Event>

<h1>Events</h1>

@if (!Model.Any())
{
    <p>No events yet. Populate <code>EventStore.Events</code> to show items.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Date</th>
                <th>Location</th>
                <th>Attendees</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
                     <tr>
                        <a asp-action="Create" class="btn btn-success mb-3">+ Create Event</a>
                    </tr>
        @foreach (var ev in Model)
        {
            <tr>
                <td>@ev.Title</td>
                <td>@ev.Date.ToString("yyyy-MM-dd")</td>
                <td>@ev.Location</td>
                <td>@ev.Attendees.Count</td>
                <td>
                    <a asp-action="Details" asp-route-id="@ev.Id" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@ev.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@ev.Id" class="btn btn-danger btn-sm">Delete</a>
                    <a class="btn btn-primary btn-sm" asp-controller="Events" asp-action="Attendees" asp-route-eventId="@ev.Id">Manage Attendees</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}